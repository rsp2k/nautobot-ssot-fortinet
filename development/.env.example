# Dev stack configuration for nautobot-ssot-fortinet.
#
# Copy to .env and edit. The .env file is gitignored.
#
# To generate a fresh secret key:
#   docker run --rm ghcr.io/nautobot/nautobot:3.1-py3.12 \
#     nautobot-server generate_secret_key

COMPOSE_PROJECT_NAME=ssot-fortinet-dev
DOMAIN=ssot-fortinet-dev.local

# Nautobot
NAUTOBOT_SECRET_KEY=changeme-generate-with-the-command-above
NAUTOBOT_SUPERUSER_NAME=admin
NAUTOBOT_SUPERUSER_EMAIL=admin@example.com
NAUTOBOT_SUPERUSER_PASSWORD=admin
NAUTOBOT_SUPERUSER_API_TOKEN=0123456789abcdef0123456789abcdef01234567

# Postgres
NAUTOBOT_DB_NAME=nautobot
NAUTOBOT_DB_USER=nautobot
NAUTOBOT_DB_PASSWORD=changeme-postgres-password

# Redis
NAUTOBOT_REDIS_PASSWORD=changeme-redis-password

# FortiGate dev target — leave empty to test the Nautobot side only.
# The seed script creates an ExternalIntegration named `fgt-dev` pointed at
# FGT_DEV_URL, with a SecretsGroup that supports either auth mode:
#   - Token mode (preferred):  set FGT_DEV_TOKEN
#   - Userpass fallback:       set FGT_DEV_USERNAME + FGT_DEV_PASSWORD
# When both are set, the client prefers token mode.
FGT_DEV_URL=https://fortigate.example.com
FGT_DEV_TOKEN=
FGT_DEV_USERNAME=
FGT_DEV_PASSWORD=
# Set to "false" to skip TLS verification (self-signed labs).
FGT_DEV_VERIFY_SSL=true
